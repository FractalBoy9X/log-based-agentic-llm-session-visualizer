# Source directory with raw Codex JSONL sessions
CODEX_SESSIONS_DIR=~/.codex/sessions

# Optional: custom venv location used by run_prettify.sh
# CODEX_VENV_DIR=.venv

# Django dev server binding used by run_prettify.sh --serve
DJANGO_HOST=127.0.0.1
DJANGO_PORT=8000

# Django settings
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_SECRET_KEY=change-this-before-production
